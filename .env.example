# Copy this file to .env and fill in your values
# Then load it with: source .env   (Linux/macOS)
#                or: set /p (Windows)

# ── Football Data API ─────────────────────────────────────────────────────
# Register free at https://www.football-data.org/client/register
# Used by scripts/update_data.py to fetch latest match results
FOOTBALL_DATA_API_KEY=your_api_key_here

# ── Flask Settings ────────────────────────────────────────────────────────
FLASK_DEBUG=0          # Set to 1 during local development
PORT=5000              # Port the server listens on
